# =============================================================================
# MIS SCHOOL WEBSITE - Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment

# -----------------------------------------------------------------------------
# CORE DJANGO SETTINGS
# -----------------------------------------------------------------------------

# Set to True for development, False for production
DEBUG=True

# Generate a new secret key for production: 
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-at-least-50-characters-long-change-this

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,misvn.edu.vn,www.misvn.edu.vn

# CSRF Trusted Origins (required for Django 4.0+)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://misvn.edu.vn,https://www.misvn.edu.vn


# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------

# Option 1: Use DATABASE_URL (recommended for production)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgres://mis_user:secure_password@localhost:5432/mis_website

# Option 2: Individual database settings (for development or specific setups)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=mis_website
# DB_USER=mis_user
# DB_PASSWORD=secure_password
# DB_HOST=localhost
# DB_PORT=5432


# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------

# SMTP Settings (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# Default sender email
DEFAULT_FROM_EMAIL=noreply@misvn.edu.vn
SERVER_EMAIL=server@misvn.edu.vn

# Admin email for error notifications
ADMIN_EMAIL=admin@misvn.edu.vn


# -----------------------------------------------------------------------------
# STATIC & MEDIA FILES
# -----------------------------------------------------------------------------

# URLs and paths for static/media files
STATIC_URL=/static/
STATIC_ROOT=/var/www/mis-website/staticfiles/

MEDIA_URL=/media/
MEDIA_ROOT=/var/www/mis-website/media/


# -----------------------------------------------------------------------------
# SECURITY SETTINGS (Production only - when DEBUG=False)
# -----------------------------------------------------------------------------

# Set to True to redirect all HTTP to HTTPS
SECURE_SSL_REDIRECT=True

# HSTS duration in seconds (31536000 = 1 year)
SECURE_HSTS_SECONDS=31536000


# -----------------------------------------------------------------------------
# CACHING (Optional)
# -----------------------------------------------------------------------------

# Redis URL for caching (leave empty to use local memory cache)
REDIS_URL=redis://localhost:6379/1


# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 
# For Gmail SMTP:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password as EMAIL_HOST_PASSWORD
#
# For PostgreSQL:
# 1. Install PostgreSQL
# 2. Create database: CREATE DATABASE mis_website;
# 3. Create user: CREATE USER mis_user WITH PASSWORD 'secure_password';
# 4. Grant privileges: GRANT ALL PRIVILEGES ON DATABASE mis_website TO mis_user;
#
# For production deployment:
# 1. Set DEBUG=False
# 2. Generate a new SECRET_KEY
# 3. Update ALLOWED_HOSTS with your domain
# 4. Configure SSL/HTTPS
# 5. Run: python manage.py collectstatic
# 6. Run: python manage.py migrate
