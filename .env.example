# Django settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Database (PostgreSQL for production)
DATABASE_URL=postgres://user:password@localhost:5432/mis_website

# Email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Static files
STATIC_URL=/static/
STATIC_ROOT=/var/www/mis-website/staticfiles/

# Media files
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/mis-website/media/
